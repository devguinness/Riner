{
  "name": "riner-lang",
  "displayName": "Riner Language",
  "description": "Syntax highlighting and language support for Riner",
  "version": "0.1.1",
  "publisher": "devguinness",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:riner"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "riner",
        "aliases": ["Riner", "riner"],
        "extensions": [".rn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "riner",
        "scopeName": "source.riner",
        "path": "./syntaxes/riner.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}