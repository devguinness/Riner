{
  "name": "riner-lang",
  "displayName": "Riner Language",
  "description": "Syntax highlighting for Riner",
  "version": "0.0.1",
  "publisher": "devguinness",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "riner",
        "aliases": ["Riner", "riner"],
        "extensions": [".rn"]
      }
    ],
    "grammars": [
      {
        "language": "riner",
        "scopeName": "source.riner",
        "path": "./syntaxes/riner.tmLanguage.json"
      }
    ]
  }
}